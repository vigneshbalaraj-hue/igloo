# Igloo Next.js app — local environment.
# Copy to .env.local and fill in. .env.local is gitignored by Next.js.

# ============================================================
# Clerk (auth)
# ============================================================
# clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Optional: where Clerk sends users after sign-in / sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/create
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/create

# ============================================================
# Supabase (mirrors root .env values)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://qgnbeudbwfrswbnxeapf.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...replace_with_root_env_value
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...replace_with_root_env_value

# ============================================================
# Razorpay (TEST MODE for Phase 6 — see project_phase6_scale_debt.md)
# Razorpay dashboard → Settings → API Keys → Generate Test Key
# ============================================================
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx
# Phase 7: webhook secret (Razorpay dashboard → Webhooks → create endpoint)
RAZORPAY_WEBHOOK_SECRET=

# ============================================================
# Modal (already deployed — Phase 5)
# ============================================================
MODAL_TRIGGER_URL=https://vigneshbalaraj-hue--igloo-trigger.modal.run
