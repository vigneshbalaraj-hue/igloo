# Igloo Next.js app — local environment.
# Copy to .env.local and fill in. .env.local is gitignored by Next.js.

# ============================================================
# Clerk (auth)
# ============================================================
# clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Optional: where Clerk sends users after sign-in / sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/create
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/create

# ============================================================
# Supabase (mirrors root .env values)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://qgnbeudbwfrswbnxeapf.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...replace_with_root_env_value
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...replace_with_root_env_value

# ============================================================
# Razorpay (TEST MODE for Phase 6 — see project_phase6_scale_debt.md)
# Razorpay dashboard → Settings → API Keys → Generate Test Key
# ============================================================
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx
# Phase 7: webhook secret (Razorpay dashboard → Webhooks → create endpoint)
RAZORPAY_WEBHOOK_SECRET=

# ============================================================
# Igloo Studio (Flask wizard on Modal)
# ============================================================
# URL of the @modal.wsgi_app() Flask host. Next.js redirects users
# here after payment capture with a signed ?token=<hmac>.
IGLOO_STUDIO_URL=https://vigneshbalaraj-hue--igloo-studio.modal.run

# HMAC-SHA256 secret used to mint studio handoff tokens. Must be
# byte-identical to IGLOO_STUDIO_SECRET in the Modal `igloo-studio`
# secret. Generate:
#   python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
IGLOO_STUDIO_SECRET=

# ============================================================
# Promo codes (migration 0010)
# ============================================================
# Feature flag for the promo-code system. Both server (validate_promo
# in /api/razorpay/order, /api/razorpay/promo-preview) and client (the
# code input on /create) check this. When unset or "false", the entire
# promo path short-circuits — wizard reverts to today's full-price
# behavior. Useful kill switch if a promo bug ships.
PROMO_CODES_ENABLED=false
NEXT_PUBLIC_PROMO_CODES_ENABLED=false

# ============================================================
# Email drip system (migration 0011)
# ============================================================
# Resend API key — generate at resend.com → API Keys.
# Restrict the key to the verified domain (igloo.video) and
# permission "Sending access" only.
RESEND_API_KEY=re_

# Clerk webhook signing secret — get from clerk.com dashboard →
# Webhooks → endpoint → Signing secret (whsec_...).
# Used by /api/clerk-webhook to verify event authenticity.
CLERK_WEBHOOK_SECRET=whsec_

# Shared secret for the internal drip sweep endpoint, called by
# pg_cron in Supabase. Generate with:
#   openssl rand -hex 32
# Or in PowerShell:
#   -join ((1..64) | ForEach-Object { '0123456789abcdef'[(Get-Random -Max 16)] })
# Same value goes here AND in the cron.schedule SQL call.
INTERNAL_DRIP_SECRET=

# Public app URL — used to construct unsubscribe links in emails.
# Defaults to https://igloo.video if not set.
NEXT_PUBLIC_APP_URL=https://igloo.video

# Admin recipients for awaiting_review notifications (migration 0012).
# Comma-separated. Empty = no notifications get sent.
ADMIN_NOTIFICATION_EMAILS=vignesh.balaraj@gmail.com,kaushiknfs6@gmail.com

# Dead — kept commented for one session as reference. The old
# headless worker trigger has been replaced by the interactive
# Flask studio hosted at IGLOO_STUDIO_URL above.
# MODAL_TRIGGER_URL=https://vigneshbalaraj-hue--igloo-trigger.modal.run
